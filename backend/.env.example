# ========== 数据库配置 ==========
DATABASE_URL=postgresql://agentflow:password@localhost:5432/agentflow

# ========== Redis 配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379

# ========== LLM 配置 ==========
# OpenAI 兼容接口
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Embedding 配置
# 如果使用 DeepSeek 等不支持 OpenAI embedding 的服务，设置 SKIP_EMBEDDING_API=true
# 或者单独配置 EMBEDDING_API_KEY 和 EMBEDDING_BASE_URL 指向 OpenAI
SKIP_EMBEDDING_API=false
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ========== 应用配置 ==========
PORT=3000
NODE_ENV=development

# ========== 日志配置 ==========
LOG_LEVEL=debug
