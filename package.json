{
  "name": "loom-plus",
  "private": true,
  "version": "1.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "vue-demi", "bcrypt", "sqlite3", "@nestjs/core", "unrs-resolver"]
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm -r --parallel run dev",
    "dev:frontend": "pnpm -C frontend dev",
    "dev:backend": "pnpm -C backend start:dev",
    "build": "pnpm -C backend build && pnpm -C frontend build:ci",
    "lint": "pnpm -C backend lint && pnpm -C frontend lint",
    "test": "pnpm -C backend test:workflow"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "frontend/**/*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": [
      "prettier --write",
      "pnpm -C frontend exec eslint --fix"
    ],
    "backend/**/*.ts": [
      "prettier --write",
      "pnpm -C backend exec eslint --fix"
    ]
  }
}
